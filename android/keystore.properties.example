# 复制本文件为 keystore.properties（与 android/ 根目录同级，已被 .gitignore 忽略）。
# 切勿将 keystore.properties、*.jks、*.keystore 提交到版本库。
#
# --- Google Play 应用签名（Play App Signing）---
# 上传到 Play 的 AAB 使用你本地的「上传密钥」签名即可；Google 会用其管理的「应用签名密钥」
# 重新签名后再分发给用户。
# 文档：https://support.google.com/googleplay/android-developer/answer/9842756
#
# --- 生成本地上传密钥库（在 android/ 目录执行，按需改别名与有效期）---
# keytool -genkeypair -v \
#   -keystore vault-upload.jks \
#   -alias upload \
#   -keyalg RSA -keysize 2048 -validity 10000 \
#   -storetype PKCS12
#
# storeFile 路径相对于 android/ 工程根目录（与 settings.gradle.kts 同级）
storeFile=vault-upload.jks
storePassword=请填写密钥库密码
keyPassword=请填写密钥密码（可与 storePassword 相同）
keyAlias=upload
